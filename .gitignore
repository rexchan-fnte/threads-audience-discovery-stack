# JSON 預設全忽略，避免金鑰誤入
*.json

# Docker / Airflow 基礎設施（本地部署用，不進 git）
docker/

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Test and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.*
!.env.example

# Coverage and test artifacts
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Editor / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs and temp files
*.log
tmp/
temp/
